# Evantis Backend — Required Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Format: jdbc:postgresql://<host>:<port>/<database_name>
DB_URL=jdbc:postgresql://localhost:5432/evantis_db
DB_USERNAME=
DB_PASSWORD=

# ── Frontend Origin (for CORS) ────────────────────────────────────────────────
# The URL of your deployed frontend. localhost:3000 is always allowed by default.
FRONTEND_URL=https://evantis.com

# ── Anthropic AI (future use) ─────────────────────────────────────────────────
# Will be used when the AI chat/assistant feature is implemented.
ANTHROPIC_API_KEY=
